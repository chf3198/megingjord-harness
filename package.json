{
  "name": "devenv-ops",
  "version": "0.1.0",
  "description": "Development environment operations: skills, monitoring, research",
  "private": true,
  "scripts": {
    "start": "node scripts/dashboard-server.js",
    "lint": "node scripts/lint.js",
    "sync": "bash scripts/sync.sh",
    "sync:dry": "bash scripts/sync.sh --dry-run",
    "deploy": "bash scripts/deploy.sh",
    "deploy:apply": "bash scripts/deploy.sh --apply",
    "health": "node scripts/health-check.js",
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed"
  },
  "keywords": [
    "devops",
    "copilot-skills",
    "monitoring",
    "dashboard"
  ],
  "author": "Curtis Franks",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  },
  "dependencies": {
    "dotenv": "^17.4.1"
  }
}
