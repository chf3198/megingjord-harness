{
  "runtime": "antigravity",
  "detection": {
    "primaryEnvMarkers": [
      "ANTIGRAVITY_AGENT",
      "ANTIGRAVITY_HOME"
    ],
    "aiAgentValue": "antigravity",
    "signal": "ANTIGRAVITY_*",
    "deltaKind": "env-marker"
  },
  "signing": {
    "team": "antigravity",
    "substrates": [
      "google"
    ]
  },
  "deploy": {
    "home": "~/.antigravity",
    "artifactClasses": [
      "settings",
      "hooks",
      "agents",
      "scripts"
    ],
    "gateCorpusHome": "~/.antigravity/scripts/global"
  },
  "hooks": {
    "configPath": ".antigravity/hooks.json",
    "emitScript": "scripts/global/antigravity-hooks-emit.js",
    "hookDir": "~/.gemini/antigravity/hooks/scripts",
    "eventCase": "camelCase",
    "events": [
      "sessionStart",
      "userPromptSubmit",
      "preToolUse",
      "postToolUse",
      "stop"
    ]
  },
  "capabilities": {
    "ghAuth": "available via stored credentials",
    "hookExecution": "lefthook runs in integrated terminal",
    "fallback": "graceful skip with advisory (G6)"
  },
  "parityWaivers": [
    {
      "surface": "scripts",
      "reason": "scripts/global gate corpus not yet deployed to this camelCase runtime",
      "promotionPath": "T2.3 (#3446) ships the scripts artifactClass via deploy.sh + the scaffold"
    }
  ]
}
