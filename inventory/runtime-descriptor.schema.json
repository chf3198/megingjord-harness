{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://megingjord/runtime-descriptor.schema.json",
  "title": "Harness Runtime Descriptor",
  "description": "One descriptor per orchestrator runtime (Epic #3411 T1.2). The data-driven input from which the T2 harness:add-runtime scaffold emits every per-runtime artifact. Each descriptor round-trips from the live registries (detect-runtime.js, deploy.sh, team-model-signatures.json, the hook config, runtime-compatibility-matrix.yml).",
  "type": "object",
  "required": ["runtime", "detection", "signing", "deploy", "hooks", "capabilities"],
  "additionalProperties": false,
  "properties": {
    "runtime": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "detection": {
      "type": "object",
      "required": ["deltaKind"],
      "additionalProperties": false,
      "properties": {
        "primaryEnvMarkers": { "type": "array", "items": { "type": "string" } },
        "aiAgentValue": { "type": "string" },
        "signal": { "type": "string" },
        "deltaKind": { "enum": ["env-marker", "ai-agent-value", "state-root", "config-path", "adapter-surface", "alias", "pure", "server-side", "none"] }
      }
    },
    "signing": {
      "type": "object",
      "required": ["team"],
      "additionalProperties": false,
      "properties": {
        "team": { "type": "string" },
        "substrates": { "type": "array", "items": { "type": "string" } }
      }
    },
    "deploy": {
      "type": "object",
      "required": ["home", "artifactClasses"],
      "additionalProperties": false,
      "properties": {
        "home": { "type": "string" },
        "artifactClasses": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "gateCorpusHome": {
          "type": "string",
          "description": "Target home for the scripts/global gate-corpus artifactClass on this runtime (e.g. ~/.cursor/scripts/global). Populated once the 'scripts' artifactClass is declared; absent on runtimes that do not yet deploy the gate corpus. T2.3 (#3446) wires this into deploy.sh for cursor + antigravity."
        }
      }
    },
    "hooks": {
      "type": "object",
      "required": ["configPath", "eventCase"],
      "additionalProperties": false,
      "properties": {
        "configPath": { "type": "string" },
        "eventCase": { "enum": ["PascalCase", "camelCase", "none"] },
        "events": { "type": "array", "items": { "type": "string" } }
      }
    },
    "capabilities": {
      "type": "object",
      "required": ["ghAuth", "hookExecution", "fallback"],
      "additionalProperties": false,
      "properties": {
        "ghAuth": { "type": "string" },
        "hookExecution": { "type": "string" },
        "fallback": { "type": "string" }
      }
    },
    "parityWaivers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["surface", "reason", "promotionPath"],
        "additionalProperties": false,
        "properties": {
          "surface": { "type": "string" },
          "reason": { "type": "string" },
          "promotionPath": { "type": "string" }
        }
      }
    }
  }
}
