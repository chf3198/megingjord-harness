{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(node scripts/global/issue-transition.js 457 in-progress testing)",
      "Bash(node scripts/global/issue-transition.js 457 testing review)",
      "Bash(node scripts/global/issue-transition.js 457 review done)",
      "Bash(python3 -m json.tool)",
      "Bash(python3 -c ' *)",
      "Bash(python3 -m json.tool .claude/settings.json)",
      "Bash(awk *)",
      "Bash(python3 -)",
      "Bash(git commit -m ' *)",
      "Bash(git stash *)"
    ],
    "ask": [],
    "deny": [],
    "additionalDirectories": [
      "/home/curtisfranks/devenv-ops/.claude"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.copilot/hooks/scripts/session_context.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.copilot/hooks/scripts/hamr_activation_check.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.copilot/hooks/scripts/manager_ticket_gate.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.copilot/hooks/scripts/goal_lens.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.copilot/hooks/scripts/userprompt_gate.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.copilot/hooks/scripts/commit_ticket_gate.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.copilot/hooks/scripts/pretool_guard.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.copilot/hooks/scripts/posttool_reminders.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.copilot/hooks/scripts/stop_reminder.py"
          }
        ]
      }
    ]
  }
}
