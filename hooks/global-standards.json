{
  "pr_policy": {
    "batch_threshold": {
      "max_files_changed": 10,
      "max_lines_diff": 500,
      "rationale": "Keeps PRs reviewable; split larger changes into stacked PRs",
      "enforcement": "BLOCKER_NOTE required in ticket if threshold exceeded with justification"
    },
    "independent_verification": {
      "rule": "ADMIN_HANDOFF signer must differ from COLLABORATOR_HANDOFF signer",
      "rationale": "Prevents self-approval; ensures cross-agent review"
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "python3 ~/.copilot/hooks/scripts/session_context.py",
        "timeout": 10
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "python3 ~/.copilot/hooks/scripts/manager_ticket_gate.py",
        "timeout": 10
      },
      {
        "type": "command",
        "command": "python3 ~/.copilot/hooks/scripts/userprompt_gate.py",
        "timeout": 10
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "python3 ~/.copilot/hooks/scripts/commit_ticket_gate.py",
        "timeout": 10
      },
      {
        "type": "command",
        "command": "python3 ~/.copilot/hooks/scripts/pretool_guard.py",
        "timeout": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "python3 ~/.copilot/hooks/scripts/posttool_reminders.py",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python3 ~/.copilot/hooks/scripts/stop_reminder.py",
        "timeout": 10
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "command": "python3 ~/.copilot/hooks/scripts/precompact_anchor.py",
        "timeout": 10
      }
    ],
    "SubagentStart": [
      {
        "type": "command",
        "command": "python3 ~/.copilot/hooks/scripts/subagent_inject.py",
        "timeout": 10
      }
    ]
  }
}
