{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "python3 ~/.cursor/hooks/scripts/session_context.py"
      },
      {
        "command": "python3 ~/.cursor/hooks/scripts/hamr_activation_check.py"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "python3 ~/.cursor/hooks/scripts/manager_ticket_gate.py"
      },
      {
        "command": "python3 ~/.cursor/hooks/scripts/goal_lens.py"
      },
      {
        "command": "python3 ~/.cursor/hooks/scripts/userprompt_gate.py"
      }
    ],
    "preToolUse": [
      {
        "command": "python3 ~/.cursor/hooks/scripts/commit_ticket_gate.py"
      },
      {
        "command": "python3 ~/.cursor/hooks/scripts/pretool_guard.py"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "python3 ~/.cursor/hooks/scripts/commit_ticket_gate.py"
      },
      {
        "command": "python3 ~/.cursor/hooks/scripts/pretool_guard.py"
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "python3 ~/.cursor/hooks/scripts/pretool_guard.py"
      }
    ],
    "afterFileEdit": [
      {
        "command": "python3 ~/.cursor/hooks/scripts/posttool_reminders.py"
      }
    ],
    "stop": [
      {
        "command": "python3 ~/.cursor/hooks/scripts/stop_reminder.py"
      }
    ],
    "subagentStart": [
      {
        "command": "python3 ~/.cursor/hooks/scripts/session_context.py"
      }
    ],
    "subagentStop": [
      {
        "command": "python3 ~/.cursor/hooks/scripts/stop_reminder.py"
      }
    ]
  }
}
