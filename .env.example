# devenv-ops secrets template
# Copy to .env and fill in values:  cp .env.example .env
# Keys are optional — features degrade gracefully without them

# --- AI Services ---
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
GOOGLE_AI_STUDIO_API_KEY=AIza...
GOOGLE_AI_STUDIO_PROJECT_NUM=
GROQ_API_KEY=gsk_...
CEREBRAS_API_KEY=csk-...

# --- Cloudflare ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_EMAIL=

# --- GitHub / VS Code ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
VSCE_PAT=
VSCE_PUBLISHER=

# --- Fleet Devices ---
OPENCLAW_DEVICE_ID=
OPENCLAW_DEVICE_PASSWORD=
SLM_DEVICE_PIN=
