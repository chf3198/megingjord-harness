# devenv-ops secrets template
# Copy to .env and fill in values:  cp .env.example .env
# Keys are optional — features degrade gracefully without them

# --- AI Services ---
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
GOOGLE_AI_STUDIO_API_KEY=AIza...
GOOGLE_AI_STUDIO_PROJECT_NUM=
GROQ_API_KEY=gsk_...
CEREBRAS_API_KEY=csk-...

# --- Cloudflare ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_EMAIL=

# --- GitHub / VS Code ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
VSCE_PAT=
VSCE_PUBLISHER=

# --- Fleet Devices (Tailscale IPs — auto-detected if omitted) ---
FLEET_IP_CHROMEBOOK_2=
FLEET_IP_PENGUIN_1=
FLEET_IP_WINDOWS_LAPTOP=
FLEET_SSH_USER=admin
OPENCLAW_URL=
OPENCLAW_DEVICE_PASSWORD=

# === OPTIONAL: Cloudflare AI Gateway cache (Phase 1 / #783) ===
# Opt-in only. If unset, clients keep direct Anthropic API behavior.
# CLOUDFLARE_AI_GATEWAY_NAME=megingjord-anthropic-cache
# ANTHROPIC_BASE_URL=https://gateway.ai.cloudflare.com/v1/<account>/<gateway>/anthropic
